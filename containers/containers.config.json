{
  "project": "WSL Container Center",
  "subtitle": "Levanta y controla contenedores con wslc — casos portados de docker-labs",
  "engine": "wslc",
  "system": {
    "diskApproxGB": 7,
    "diskNote": "Suma de tamaños reportados (~7.4 GB); las capas base compartidas reducen el disco real.",
    "ramMinGB": 4,
    "ramRecGB": 8,
    "ramComfortGB": 16,
    "cpuMin": 2,
    "cpuRec": 4,
    "heaviestCase": "11-elasticsearch (~2-3 GB de RAM)",
    "note": "Rara vez se corren los 12 a la vez. El mínimo cubre WSL2 + panel + un caso ligero; el recomendado cubre los casos pesados."
  },
  "portBase": 8100,
  "cases": [
    {
      "id": "01",
      "name": "node-api",
      "title": "API Node.js",
      "description": "API REST mínima en Node.js (imagen node:20-alpine, http nativo).",
      "category": "starter",
      "port": 8101,
      "url": "http://localhost:8101",
      "healthProtocol": "http",
      "build": [
        {
          "image": "wsl-labs/node-api:latest",
          "context": "containers/01-node-api"
        }
      ],
      "containers": [
        {
          "name": "wslc-node-api",
          "image": "wsl-labs/node-api:latest",
          "ports": [
            "8101:3000"
          ]
        }
      ],
      "requirements": {
        "imageSizeMB": 136,
        "ramIdleMB": 9,
        "ramMinMB": 128,
        "ramRecMB": 256
      },
      "limits": {
        "memMB": 256,
        "cpus": 0.5
      }
    },
    {
      "id": "03",
