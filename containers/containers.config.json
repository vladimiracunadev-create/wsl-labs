      "id": "04",
      "name": "redis-cache",
      "title": "Cache Redis + app",
      "description": "App Node que consulta Redis (redis:7-alpine) por una red wslc.",
      "category": "platform",
      "port": 8105,
      "url": "http://localhost:8105",
      "healthProtocol": "http",
      "network": "wslc-redis-net",
      "build": [
        {
          "image": "wsl-labs/redis-app:latest",
          "context": "containers/04-redis-cache"
        }
      ],
      "containers": [
        {
          "name": "wslc-redis",
          "image": "redis:7-alpine",
          "ports": []
        },
        {
          "name": "wslc-redis-app",
          "image": "wsl-labs/redis-app:latest",
          "ports": [
            "8105:3000"
          ],
          "env": [
            "REDIS_HOST=wslc-redis"
          ]
        }
      ],
      "requirements": {
        "imageSizeMB": 175,
        "ramIdleMB": 13,
        "ramMinMB": 256,
        "ramRecMB": 512
      },
      "limits": {
