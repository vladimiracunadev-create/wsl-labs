      "id": "11",
      "name": "elasticsearch",
      "title": "Elasticsearch",
      "description": "Motor de búsqueda Elasticsearch 8 (nodo único, seguridad off).",
      "category": "infra",
      "port": 8113,
      "url": "http://localhost:8113",
      "healthProtocol": "http",
      "build": [],
      "containers": [
        {
          "name": "wslc-elasticsearch",
          "image": "elasticsearch:8.11.0",
          "ports": [
            "8113:9200"
          ],
          "env": [
            "discovery.type=single-node",
            "xpack.security.enabled=false",
            "ES_JAVA_OPTS=-Xms512m -Xmx512m"
          ],
          "volumes": [
            "wslc-esdata:/usr/share/elasticsearch/data"
          ]
        }
      ],
      "requirements": {
        "imageSizeMB": 1410,
        "ramIdleMB": 910,
        "ramMinMB": 2048,
        "ramRecMB": 3072
      },
      "limits": {
        "memMB": 3072,
        "cpus": 2.0
      }
