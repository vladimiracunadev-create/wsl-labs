    {
      "id": "05",
      "name": "postgres-api",
      "title": "API + PostgreSQL",
      "description": "API Python conectada a PostgreSQL (postgres:15) por una red wslc.",
      "category": "platform",
      "port": 8106,
      "url": "http://localhost:8106",
      "healthProtocol": "http",
      "network": "wslc-pg-net",
      "build": [
        {
          "image": "wsl-labs/pg-app:latest",
          "context": "containers/05-postgres-api"
        }
      ],
      "containers": [
        {
          "name": "wslc-postgres",
          "image": "postgres:15",
          "ports": [],
          "env": [
            "POSTGRES_PASSWORD=wsl-labs",
            "POSTGRES_DB=app"
          ],
          "volumes": [
            "wslc-pgdata:/var/lib/postgresql/data"
          ]
        },
        {
          "name": "wslc-pg-app",
          "image": "wsl-labs/pg-app:latest",
          "ports": [
            "8106:8000"
          ],
          "env": [
            "PG_HOST=wslc-postgres"
          ]
        }
      ],
      "requirements": {
        "imageSizeMB": 493,
        "ramIdleMB": 36,
        "ramMinMB": 512,
        "ramRecMB": 1024
      },
      "limits": {
        "memMB": 1024,
        "cpus": 1.0
      }
    },
    {
      "id": "07",
      "name": "rabbitmq",
      "title": "RabbitMQ (mensajería)",
