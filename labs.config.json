      "name": "nodejs-entorno-dev",
      "path": "labs/07-nodejs-entorno-dev",
      "type": "service",
      "status": "ready",
      "description": "API Node.js de ejemplo en localhost:8082.",
      "url": "http://localhost:8082",
      "port": 8082,
      "startCommand": "cd \"$WSL_LABS_ROOT/examples/node-api\" && PORT=8082 nohup node server.js > /tmp/wsl-labs-node.log 2>&1 &",
      "stopCommand": "pkill -f 'node server.js' || true",
      "logsCommand": "tail -n 50 /tmp/wsl-labs-node.log 2>/dev/null || true",
      "healthProtocol": "http"
    },
    {
      "id": "08",
      "name": "python-entorno-dev",
      "path": "labs/08-python-entorno-dev",
      "type": "service",
      "status": "ready",
      "description": "App Flask de ejemplo en localhost:8083.",
      "url": "http://localhost:8083",
      "port": 8083,
      "startCommand": "cd \"$WSL_LABS_ROOT/examples/python-flask\" && PORT=8083 nohup python3 app.py > /tmp/wsl-labs-flask.log 2>&1 &",
      "stopCommand": "pkill -f 'app.py' || true",
      "logsCommand": "tail -n 50 /tmp/wsl-labs-flask.log 2>/dev/null || true",
      "healthProtocol": "http"
    },
